# Host path to your ebook library (mounted read-only into the container at /library)
HOST_LIBRARY_PATH=/path/to/your/books

# Container user/group IDs (match your host user to avoid permission issues)
# PUID=1000
# PGID=1000

# Timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# TZ=UTC

# SMTP (send-to-kindle, email notifications)
# SHELFRAT_SMTP_HOST=smtp.gmail.com
# SHELFRAT_SMTP_PORT=587
# SHELFRAT_SMTP_USER=you@gmail.com
# SHELFRAT_SMTP_PASSWORD=your-app-password
# SHELFRAT_SMTP_FROM=you@gmail.com
# SHELFRAT_SMTP_ENCRYPTION=starttls

# OIDC (single sign-on)
# SHELFRAT_APP_URL=https://shelf.example.com
# SHELFRAT_OIDC_ISSUER_URL=https://auth.example.com/realms/main
# SHELFRAT_OIDC_CLIENT_ID=shelfrat
# SHELFRAT_OIDC_CLIENT_SECRET=your-client-secret
# SHELFRAT_OIDC_AUTO_REGISTER=true
# SHELFRAT_OIDC_PROVIDER_NAME=Authentik

# Metadata providers
# SHELFRAT_HARDCOVER_API_KEY=Bearer eyJhb...
# SHELFRAT_METADATA_PROVIDERS=["openlibrary","googlebooks","hardcover"]
# SHELFRAT_METADATA_RETRY_HOURS=24

# Job scheduling (seconds, 0 to disable)
# SHELFRAT_JOB_CADENCE_LIBRARY_SCAN=300
